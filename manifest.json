{
  "manifest_version": 2,
  "name": "Mastodon Thread Reader",
  "version": "0.1.0",
  "description": "Read any Mastodon thread as a clean, single readable page.",
  "author": "Mastodon Thread Reader",

  "icons": {
    "48": "icons/icon-48.svg",
    "96": "icons/icon-96.svg"
  },

  "browser_action": {
    "default_popup": "popup.html",
    "default_title": "Mastodon Thread Reader",
    "default_icon": {
      "48": "icons/icon-48.svg",
      "96": "icons/icon-96.svg"
    }
  },

  "permissions": [
    "activeTab",
    "storage",
    "https://*/*"
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "masto-thread@chtisuisse",
      "strict_min_version": "142.0",
      "data_collection_permissions": {
        "required": ["none"],
        "optional": []
      }
    }
  },

  "options_ui": {
    "page": "options.html",
    "browser_style": false
  }
}
